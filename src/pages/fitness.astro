---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import ContactCta from '@/components/ui/ContactCta.astro';
import KursDetailHero from '@/components/sections/KursDetailHero.astro';
import FaqSection from '@/components/sections/FaqSection.astro';
import fitnessImg from '../assets/images/NoGi_1.jpeg';
---

<Base
  title="Fitness & Conditioning Ludwigshafen | Circle of Life BJJ"
  description="Fitness & Conditioning für Grappler in Ludwigshafen. Bodyweight-Training, Mobility, Core & BJJ-spezifische Drills. Kostenlose Probestunde."
  canonical="https://circleoflife-bjj.de/fitness"
  bodyClass="page-fitness"
>

  <KursDetailHero
    badge="Conditioning"
    title="Fitness & Conditioning"
    headingId="fit-hero"
    lead="Kondition &amp; Fitness ohne Geräte in Ludwigshafen &amp; Mannheim: Wir arbeiten mit Körpergewicht, Mobility und Stabilität – BJJ-spezifische Drills statt Maschinentraining. Dehn-, Balance- und Core-Übungen verbessern Haltung, Atmung und Erholung. Ob aus Ludwigshafen-Ruchheim, Mannheim, Frankenthal oder Bad Dürkheim – unser Conditioning stärkt Grappler, MMA-Athleten und Fitnessfans."
    note="Mitbringen: Sportschuhe für Off-Mat-Übungen, Handtuch, Wasser."
    anchors={[
      { href: '#was-ist',    label: 'Inhalt' },
      { href: '#geschichte', label: 'Warum & Nutzen' },
      { href: '#faq',        label: 'FAQ' },
    ]}
  />


  <section id="was-ist" style="padding:2.5em 0;" data-aos="fade-up">
    <div class="container">
      <div class="seo-split">
        <div class="seo-split__copy">
          <p class="eyebrow">Inhalt</p>
          <h2 style="font-size:1.5rem;font-weight:700;margin-bottom:.75rem;">Was machen wir im Conditioning?</h2>
          <p>Funktionelles Bodyweight-Training für Grappler aus Ludwigshafen, Mannheim und der Pfalz: Movement Prep, Mobility, Core-Stabilität und BJJ-Drills wie Hip-Escape, Technical Stand-up oder Sprawls – ganz ohne Maschinen.</p>
          <ul class="seo-bullets">
            <li>Mobility für Hüfte, Wirbelsäule &amp; Schultern</li>
            <li>Stabilität, Core &amp; Atemkontrolle</li>
            <li>Flow-Sequenzen inspiriert von Advanced Yoga</li>
            <li>BJJ-spezifische Drills für Timing &amp; Technik</li>
            <li>Regelmäßige Sessions für Fitness, Rehabilitation &amp; MMA</li>
          </ul>
          <div style="background:var(--color-surface);border-radius:.75rem;padding:1rem;margin-top:.75rem;font-size:.9rem;">
            <strong>Prinzip:</strong> Technik vor Last. Ein stabiles Fundament schützt vor Verletzungen und verbessert dein Grappling.
          </div>
        </div>
        <div class="seo-split__media">
          <Image src={fitnessImg} loading="lazy" decoding="async" alt="Conditioning Training" widths={[480, 800]} sizes="(max-width: 767px) 95vw, 50vw" style="width:100%;border-radius:1.5rem;object-fit:cover;" />
        </div>
      </div>
    </div>
  </section>

  <section id="geschichte" style="padding:2.5em 0;" data-aos="fade-up">
    <div class="container">
      <div class="seo-split">
        <div class="seo-split__copy">
          <p class="eyebrow">Warum Conditioning?</p>
          <h2 style="font-size:1.5rem;font-weight:700;margin-bottom:.75rem;">Mehr Körperspannung, bessere Atmung</h2>
          <p>Mehr Mobility und Core-Kontrolle bedeutet stabilere Frames, effizienteren Druckaufbau und verletzungspräventives Training. Du regenerierst schneller zwischen Runden und bringst saubere Technik aufs Mattenlevel.</p>
          <ul class="seo-bullets">
            <li>Stabile Hüfte &amp; Wirbelsäule → bessere Guard &amp; Passing Positionen</li>
            <li>Griffkraft &amp; Atemarbeit → längere Runden ohne Spannung zu verlieren</li>
            <li>Balance &amp; Flow → flüssigere Übergänge im Gi &amp; No-Gi</li>
          </ul>
          <p style="font-size:.875rem;color:var(--color-text-muted);">Weiterführend: <a href="https://en.wikipedia.org/wiki/Strength_and_conditioning" target="_blank" rel="nofollow noopener" style="color:var(--color-accent);">Wikipedia – Strength &amp; Conditioning</a></p>
        </div>
        <div class="seo-split__media">
          <div style="background:var(--color-surface);border-radius:1rem;padding:1.5rem;width:100%;border:1px solid var(--color-border);">
            <span class="eyebrow">Trainingsschwerpunkte</span>
            <ul style="list-style:none;padding:0;margin:0;font-size:.9rem;display:flex;flex-direction:column;gap:.4rem;">
              <li>• Core &amp; Atemarbeit</li>
              <li>• Mobility Flows</li>
              <li>• Grappling Drills &amp; Footwork</li>
              <li>• Regeneration &amp; Flexibilität</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FaqSection page="fitness" />

  <ContactCta
    eyebrow="Fitness Training anfragen"
    headline="Conditioning & Kraft für BJJ-Athleten in Ludwigshafen"
    subline="Gezieltes Ergänzungstraining für Kampfsportler – stärker auf der Matte, weniger Verletzungen. Komm vorbei und teste es kostenlos."
    ctaLabel="Probetraining sichern"
    showContact={true}
    align="left"
  />

</Base>
