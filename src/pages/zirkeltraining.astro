---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import SvgIcon from '../components/ui/SvgIcon.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import ZirkelVariantenSection from '../components/sections/ZirkelVariantenSection.astro';
import FaqSection from '@/components/sections/FaqSection.astro';
import { IconCheck } from '@/icons/index';
import ContactCta from '@/components/ui/ContactCta.astro';
import halleImg from '../assets/images/col_halle.jpeg';
---

<Base
  title="Zirkeltraining Ludwigshafen | Mamas & 60+ | Circle of Life BJJ"
  description="Zirkeltraining in Ludwigshafen-Ruchheim: Dienstags für Mamas (mit Baby willkommen) und Generation 60+. Ganzkörpertraining für jedes Fitnesslevel bei Circle of Life BJJ."
  canonical="https://circleoflife-bjj.de/zirkeltraining"
  bodyClass="page-zirkeltraining"
>

  <!-- Hero -->
  <section class="subpage-hero" aria-labelledby="zirkel-hero-title" data-aos="fade-up">
    <div class="container" style="padding-bottom:4rem;">
      <span class="subpage-badge">Zirkeltraining</span>
      <h1 id="zirkel-hero-title">Zirkeltraining</h1>
      <p class="lead" style="max-width:65ch;">
        Ganzkörper-Zirkeltraining in Ludwigshafen-Ruchheim – jeden Dienstag.
        Ob als frische Mama, mit Kleinkind dabei, oder aktiv in der Generation 60+:
        Wir trainieren gemeinsam in familiärer Atmosphäre, professionell begleitet und für jedes Fitnesslevel geeignet.
      </p>
      <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:1.5rem;">
        <a class="btn-brand btn-lg" href="/#probetraining">Jetzt anmelden</a>
        <a class="btn-outline-light btn-lg" href="tel:+4917661990534">
          0176&nbsp;61990534 anrufen
        </a>
      </div>
      <nav style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:1rem;" aria-label="Abschnitts-Shortcuts">
        <a href="#kurse" style="color:rgba(255,255,255,.75);font-size:.9rem;">Kurse & Zeiten</a>
        <a href="#preise" style="color:rgba(255,255,255,.75);font-size:.9rem;">Preise</a>
        <a href="#faq" style="color:rgba(255,255,255,.75);font-size:.9rem;">FAQ</a>
      </nav>
    </div>
  </section>


  <ZirkelVariantenSection />

  <!-- What to expect -->
  <section id="was-ist" class="cv-section bg-surface" style="padding:2.5em 0;" data-aos="fade-up">
    <div class="container">
      <div class="seo-split">
        <div class="seo-split__copy">
          <p class="eyebrow">Was erwartet dich?</p>
          <h2 style="font-size:1.5rem;font-weight:700;margin-bottom:.75rem;">
            Zirkeltraining – was steckt dahinter?
          </h2>
          <p style="margin-bottom:1rem;">
            Beim Zirkeltraining durchläufst du mehrere Stationen nacheinander – jede Station trainiert andere Muskelgruppen.
            Das Ergebnis: maximale Effizienz in kurzer Zeit, ein echter Ganzkörperstimulus und kaum Wartezeiten.
          </p>
          <p style="margin-bottom:1rem;">
            Bei Circle of Life BJJ setzen wir auf funktionelles Training mit Körpergewicht, kleinen Geräten
            und viel Bewegung – kein Maschinentraining, kein Einerlei.
          </p>
          <ul class="seo-bullets">
            <li>Kräftigung, Mobilität & Gleichgewicht in einer Einheit</li>
            <li>Individuell angepasst an dein Fitnesslevel</li>
            <li>Kleine Gruppen, persönliche Begleitung</li>
            <li>Familiäre Atmosphäre & guter Austausch</li>
          </ul>
        </div>
        <div class="seo-split__media">
          <Image
            src={halleImg}
            alt="Trainingshalle Circle of Life BJJ"
            widths={[480, 800]}
            sizes="(max-width:767px) 95vw, 50vw"
            loading="lazy"
            style="width:100%;border-radius:1.5rem;object-fit:cover;max-height:480px;"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Preise -->
  <section id="preise" class="cv-section" style="padding:2.5em 0;" data-aos="fade-up">
    <div class="container">
      <SectionHeader
        title="Preise"
        subtitle="Flexible Zehnerkarte – keine Mitgliedschaft nötig."
      />
      <div class="mx-auto max-w-md rounded-2xl border border-border bg-white p-8 shadow-(--shadow-card) text-center">
        <p class="eyebrow">Zirkeltraining 60+</p>
        <div class="my-4">
          <span class="text-5xl font-extrabold text-primary">100&thinsp;€</span>
          <span class="text-sm text-text-muted"> / Zehnerkarte</span>
        </div>
        <ul class="mb-6 space-y-2 text-left">
          {(['10 Trainingseinheiten', 'Kein Abo, kein Vertrag', 'Gi & No-Gi nutzbar'] as string[]).map((f: string) => (
            <li class="flex items-center gap-2 text-sm text-text-muted">
              <SvgIcon icon={IconCheck} class="w-4 h-4 shrink-0 text-accent" />
              {f}
            </li>
          ))}
        </ul>
        <p class="text-sm text-text-muted italic">
          Zirkeltraining für Mamas: Preis auf Anfrage – ruf uns einfach an.
        </p>
        <a
          href="tel:+4917661990534"
          class="mt-6 block w-full rounded-xl bg-accent py-3 text-sm font-bold text-primary transition-colors hover:bg-primary hover:text-white"
        >
          0176&nbsp;61990534 anrufen
        </a>
      </div>
    </div>
  </section>

  <FaqSection page="zirkeltraining" />

  <ContactCta
    eyebrow="Zirkeltraining anfragen"
    headline="Zirkeltraining in Ludwigshafen – für Mamas & 60+"
    subline="Dienstags in Ludwigshafen-Ruchheim – flexibel, familiär, für jedes Fitnesslevel. Zehnerkarte ab 100€, Anmeldung per Telefon oder WhatsApp."
    ctaLabel="Jetzt anmelden"
    cta2Label="0176 61990534 anrufen"
    cta2Href="tel:+4917661990534"
    showContact={true}
    align="left"
  />

</Base>
