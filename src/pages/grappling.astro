---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import ContactCta from '@/components/ui/ContactCta.astro';
import KursDetailHero from '@/components/sections/KursDetailHero.astro';
import FaqSection from '@/components/sections/FaqSection.astro';
import nogiImg from '../assets/images/kurse/nogi_grappling_3.jpeg';
---

<Base
  title="No-Gi Grappling Ludwigshafen | Circle of Life BJJ"
  description="No-Gi Grappling in Ludwigshafen & Mannheim. ADCC-orientiertes Training, Leglocks, Wrestling Entries & Submissions. Kostenlose Probestunde für Einsteiger."
  canonical="https://circleoflife-bjj.de/grappling"
  bodyClass="page-grappling"
>

  <KursDetailHero
    badge="No-Gi Training"
    title="No-Gi Grappling"
    headingId="nogi-hero"
    lead="Grappling ohne Gi in Ludwigshafen &amp; Mannheim: Grip-Fighting, Takedowns, Kontrolle &amp; Submissions – technisch, schnell, sicher. Unser No-Gi Programm richtet sich an Kampfsportler aus der gesamten Rhein-Neckar-Region. Wir trainieren ADCC-orientierte Systems, Leglocks mit Sicherheitsprotokoll und MMA-taugliche Clinch-Strategien."
    note="Kurze Hose/Rashguard, Flip-Flops für die Mattenzone – fertig."
    anchors={[
      { href: '#was-ist',    label: 'Was ist No-Gi?' },
      { href: '#geschichte', label: 'Geschichte & Nutzen' },
      { href: '#faq',        label: 'FAQ' },
    ]}
  />


  <section id="was-ist" style="padding:2.5em 0;" data-aos="fade-up">
    <div class="container">
      <div class="seo-split">
        <div class="seo-split__copy">
          <p class="eyebrow">Grundlagen</p>
          <h2 style="font-size:1.5rem;font-weight:700;margin-bottom:.75rem;">Was ist No-Gi Grappling?</h2>
          <p>No-Gi in unserer Kampfsportschule nutzt die gleichen Positionsprinzipien wie BJJ, aber ohne Gi-Griffe. Du arbeitest mit Underhooks, Wrist Control, Head-Position und Bodylocks für Entries, Kontrollen und Submissions.</p>
          <ul class="seo-bullets">
            <li>Ablauf: Stand → Takedown → Guard/Passing → Kontrolle → Submission</li>
            <li>Fokus auf Bewegung, Frames und Timing</li>
            <li>Klare Sicherheitsregeln, vor allem bei Leglocks</li>
            <li>Perfekt für MMA, Selbstverteidigung &amp; Grappling-Wettkämpfe</li>
          </ul>
          <div style="background:var(--color-surface);border-radius:.75rem;padding:1rem;margin-top:.75rem;font-size:.9rem;">
            <strong>Hinweis:</strong> Rashguard/T-Shirt, Shorts/Spats und Flip-Flops für die Mattenzone. Fingernägel kurz, Hygiene beachten.
          </div>
        </div>
        <div class="seo-split__media">
          <Image src={nogiImg} loading="lazy" decoding="async" alt="No-Gi Grappling Training" widths={[480, 800]} sizes="(max-width: 767px) 95vw, 50vw" style="width:100%;border-radius:1.5rem;object-fit:cover;" />
        </div>
      </div>
    </div>
  </section>

  <section id="geschichte" style="padding:2.5em 0;" data-aos="fade-up">
    <div class="container">
      <div class="seo-split">
        <div class="seo-split__copy">
          <p class="eyebrow">Warum No-Gi?</p>
          <h2 style="font-size:1.5rem;font-weight:700;margin-bottom:.75rem;">Geschichte &amp; Einsatzbereiche</h2>
          <p>No-Gi ist die gi-freie Variante des BJJ und wurde durch Submission-Only-Formate und MMA populär. In Ludwigshafen und der gesamten Rhein-Neckar-Region trainieren wir ohne Stoffgriffe, mit Fokus auf Kontrolle, Transitions, Leglocks und schnellen Entries.</p>
          <ul class="seo-bullets">
            <li>Trainiere Selbstverteidigung, MMA oder ADCC/EBI-Regelwerke</li>
            <li>Verbessere Takedowns, Scrambles und Explosivität</li>
            <li>Leglocks &amp; Druckaufbau werden progressiv und sicher vermittelt</li>
          </ul>
          <p style="font-size:.875rem;color:var(--color-text-muted);">Weiterführend: <a href="https://de.wikipedia.org/wiki/Brazilian_Jiu-Jitsu" target="_blank" rel="nofollow noopener" style="color:var(--color-accent);">Wikipedia – Brazilian Jiu-Jitsu</a></p>
        </div>
        <div class="seo-split__media">
          <div style="background:var(--color-surface);border-radius:1rem;padding:1.5rem;width:100%;border:1px solid var(--color-border);">
            <span class="eyebrow">Trainingsziele</span>
            <ul style="list-style:none;padding:0;margin:0;font-size:.9rem;display:flex;flex-direction:column;gap:.4rem;">
              <li>• Wrestling Entries &amp; Clinch</li>
              <li>• Guard Passing ohne Griffe</li>
              <li>• Leglocks &amp; Back Takes</li>
              <li>• Competition Prep (ADCC-Style)</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FaqSection page="grappling" />

  <ContactCta
    eyebrow="No-Gi Grappling anfangen"
    headline="No-Gi Grappling in Ludwigshafen – für Anfänger & Wettkämpfer"
    subline="Dynamisches Training ohne Kimono – Leglocks, Heelhooks, Guillotines. Das effektivste Kampfsportsystem der Rhein-Neckar-Region."
    ctaLabel="Jetzt einsteigen"
    showContact={true}
    align="left"
  />

</Base>
