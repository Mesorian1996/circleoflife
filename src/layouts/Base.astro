---
import '../styles/theme.css';
import NavigationMenu from '../components/global/NavigationMenu.astro';
import Footer from '../components/global/Footer.astro';
import ScrollToTop from '../components/widgets/ScrollToTop.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDesc?: string;
  ogImage?: string;
  ogUrl?: string;
  bodyClass?: string;
  jsonLd?: object[];
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDesc,
  ogImage = 'https://circleoflife-bjj.de/assets/social/og-cover.jpeg',
  ogUrl,
  bodyClass = '',
  jsonLd = [],
} = Astro.props;

const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc  = ogDesc  ?? description;
const resolvedOgUrl   = ogUrl   ?? canonical;
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Circle of Life Jiu-Jitsu" />
  <meta name="keywords" content="Brazilian Jiu-Jitsu Ludwigshafen, BJJ Mannheim, Grappling Rhein-Neckar, No-Gi Training, Kampfsport Probetraining, Kinder BJJ Rheinland-Pfalz" />
  <meta name="geo.region" content="DE-RP" />
  <meta name="geo.placename" content="Ludwigshafen am Rhein" />

  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="de" href={canonical} />

  <meta property="og:type"         content="website" />
  <meta property="og:site_name"    content="Circle of Life Jiu-Jitsu" />
  <meta property="og:locale"       content="de_DE" />
  <meta property="og:url"          content={resolvedOgUrl} />
  <meta property="og:title"        content={resolvedOgTitle} />
  <meta property="og:description"  content={resolvedOgDesc} />
  <meta property="og:image"        content={ogImage} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt"    content="Circle of Life BJJ – Training auf der Matte in Mannheim" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={resolvedOgTitle} />
  <meta name="twitter:description" content={resolvedOgDesc} />
  <meta name="twitter:image"       content={ogImage} />
  <meta name="twitter:image:alt"   content="Circle of Life BJJ – Training auf der Matte in Mannheim" />

  <link rel="icon"             href="/favicon-32.png"       sizes="32x32"   type="image/png" />
  <link rel="icon"             href="/favicon-192.png"      sizes="192x192" type="image/png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="icon"             href="/favicon.ico"          sizes="any" />

  <slot name="head" />

  {jsonLd.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}
</head>

<body class={bodyClass}>

  <NavigationMenu currentPath={Astro.url.pathname} />

  <main id="main-content" tabindex="-1" role="main">
    <slot />
  </main>

  <Footer />
  <ScrollToTop />

  <!-- AOS scroll animations -->
  <script>
    import AOS from 'aos';
    document.addEventListener('DOMContentLoaded', () => {
      AOS.init({ once: true, duration: 600, easing: 'ease-out' });
    });
  </script>

  <!-- Preline UI — accordion -->
  <script>
    import 'preline';
  </script>

  <!-- Flowbite — navbar dropdown / collapse -->
  <script src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js" is:inline></script>

</body>
</html>
