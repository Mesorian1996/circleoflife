---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'center' | 'left';
  light?: boolean;
}

const { eyebrow, title, subtitle, align = 'center', light = false } = Astro.props;
---

<header
  class:list={[
    'section-head',
    { 'is-light': light },
    align === 'left' ? 'text-left' : 'text-center',
  ]}
  data-aos="fade-up"
>
  {eyebrow && (
    <span class="eyebrow">{eyebrow}</span>
  )}
  <h2 class="section-title">{title}</h2>
  {subtitle && (
    <p class="section-subtitle" data-aos="fade-up" data-aos-delay="100" set:html={subtitle} />
  )}
</header>
