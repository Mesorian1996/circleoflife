---
import type { PreisCard } from '@/data/preise'

interface Props {
  data: PreisCard
}

const { data } = Astro.props
const { titel, preisText, periode, beschreibung,
        features, ctaLabel, ctaHref,
        highlighted, badge, hinweis } = data
---

<div class:list={[
  "relative flex flex-col rounded-xl border p-6 transition-all duration-300",
  highlighted
    ? "bg-white border-accent ring-2 ring-accent/30 shadow-(--shadow-card-hover) scale-[1.02]"
    : "bg-white border-border shadow-(--shadow-card) hover:shadow-(--shadow-card-hover) hover:-translate-y-1"
]}>

  <!-- Badge -->
  {badge && (
    <span class="absolute -top-3 left-1/2 -translate-x-1/2
                 px-3 py-1 rounded-full text-xs font-bold
                 bg-accent text-primary whitespace-nowrap">
      {badge}
    </span>
  )}

  <!-- Header -->
  <div class="mb-4">
    <h3 class="font-heading font-bold text-lg text-primary mb-1">
      {titel}
    </h3>
    <p class="text-text-muted text-sm">{beschreibung}</p>
  </div>

  <!-- Preis -->
  <div class="flex items-end gap-1 mb-5">
    <span class:list={[
      "font-heading font-bold text-4xl leading-none",
      highlighted ? "text-accent" : "text-primary"
    ]}>
      {preisText}
    </span>
    <span class="text-text-muted text-sm mb-1">{periode}</span>
  </div>

  <!-- Divider -->
  <hr class="border-border mb-5" />

  <!-- Features -->
  <ul class="space-y-3 mb-6 flex-1">
    {features.map(f => (
      <li class="flex items-start gap-2.5 text-sm text-text-muted">
        <svg class="w-4 h-4 shrink-0 mt-0.5 text-accent"
             fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"/>
        </svg>
        {f}
      </li>
    ))}
  </ul>

  <!-- Hinweis -->
  {hinweis && (
    <p class="text-text-faint text-xs mb-4 text-center">{hinweis}</p>
  )}

  <!-- CTA -->
  <a href={ctaHref}
     class:list={[
       "block w-full py-2.5 px-4 rounded-xl text-sm font-bold text-center transition-colors duration-200",
       highlighted
         ? "bg-accent text-primary hover:bg-primary hover:text-white"
         : "border border-border text-primary bg-white hover:bg-surface hover:border-accent"
     ]}>
    {ctaLabel}
  </a>

</div>
