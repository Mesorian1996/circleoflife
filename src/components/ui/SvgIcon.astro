---
interface Props {
  icon: string;    // raw SVG string from src/icons/index.ts
  class?: string;  // Tailwind classes e.g. "w-5 h-5 text-accent"
  label?: string;  // aria-label for accessibility
}

const { icon, class: cls = 'w-5 h-5', label } = Astro.props;
---

<span
  class:list={['inline-flex items-center justify-center [&>svg]:w-full [&>svg]:h-full', cls]}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  set:html={icon}
/>
