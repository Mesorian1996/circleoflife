---
import { Icon } from 'astro-icon/components';

interface Props {
  label: string;
  href: string;
  variant?: 'primary' | 'outline' | 'gold';
  size?: 'sm' | 'md' | 'lg';
  icon?: string;
  iconRight?: boolean;
  external?: boolean;
  class?: string;
}

const {
  label,
  href,
  variant = 'primary',
  size = 'md',
  icon,
  iconRight = false,
  external = false,
  class: extraClass = '',
} = Astro.props;

const cls = {
  primary: 'btn-brand',
  outline: 'btn-outline-light',
  gold:    'hero-btn--highlight',
}[variant];

const sz = { sm: 'btn-sm', md: '', lg: 'btn-lg' }[size];
---

<a
  href={href}
  class:list={[cls, sz, extraClass].filter(Boolean)}
  {...external ? { target: '_blank', rel: 'noopener' } : {}}
>
  {icon && !iconRight && (
    <Icon name={icon} class="w-4 h-4" aria-hidden="true" />
  )}
  {label}
  {icon && iconRight && (
    <Icon name={icon} class="w-4 h-4" aria-hidden="true" />
  )}
</a>
