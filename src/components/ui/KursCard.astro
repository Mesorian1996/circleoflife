---
import { Icon } from 'astro-icon/components';

interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  delay?: number;
}

const { title, description, href, icon, delay = 0 } = Astro.props;
---

<a
  href={href}
  class="group block rounded-xl border border-border bg-white p-6 shadow-(--shadow-card) hover:shadow-(--shadow-card-hover) hover:-translate-y-1 transition-all duration-200"
  data-aos="fade-up"
  data-aos-delay={delay}
>
  <div class="mb-4 inline-flex size-12 items-center justify-center rounded-full bg-gradient-to-br from-gold-2 to-accent text-primary">
    <Icon name={icon} class="size-5" aria-hidden="true" />
  </div>
  <h3 class="text-lg font-bold text-text group-hover:text-accent transition-colors">{title}</h3>
  <p class="mt-2 text-sm text-text-muted leading-relaxed">
    <slot>{description}</slot>
  </p>
  <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-accent">
    Mehr erfahren
    <Icon name="lucide:arrow-right" class="size-4 transition-transform group-hover:translate-x-1" aria-hidden="true" />
  </span>
</a>
