---
/**
 * ContactCta
 * @description Wiederverwendbarer CTA-Block — Eyebrow, Headline,
 *              Subline, zwei Buttons, Kontaktlinks.
 *
 * @prop {string} eyebrow        - Goldener Eyebrow-Text (uppercase)
 * @prop {string} headline       - Weiße Hauptüberschrift
 * @prop {string} subline        - Weißer Beschreibungstext
 * @prop {string} [ctaLabel]     - Primärer CTA-Text
 * @prop {string} [ctaHref]      - Primärer CTA-Link
 * @prop {string} [cta2Label]    - Sekundärer CTA-Text
 * @prop {string} [cta2Href]     - Sekundärer CTA-Link
 * @prop {boolean} [showContact] - Kontaktlinks anzeigen (default: true)
 * @prop {'left'|'center'} [align] - Ausrichtung (default: 'left')
 */

import { IconPhone, IconWhatsApp, IconInstagram } from '@/icons/index';
import SvgIcon from '@/components/ui/SvgIcon.astro';

interface Props {
  eyebrow:       string;
  headline:      string;
  subline:       string;
  ctaLabel?:     string;
  ctaHref?:      string;
  cta2Label?:    string;
  cta2Href?:     string;
  showContact?:  boolean;
  align?:        'left' | 'center';
}

const {
  eyebrow,
  headline,
  subline,
  ctaLabel    = 'Probetraining sichern',
  ctaHref     = '/#probetraining',
  cta2Label   = 'Route zum Gym',
  cta2Href    = 'https://www.google.com/maps?q=Am+Herrschaftsweiher+17,+67071+Ludwigshafen',
  showContact = true,
  align       = 'left',
} = Astro.props;

const isCenter = align === 'center';
---

<div class="py-12 md:py-16 bg-surface-dark">
  <div class:list={[
    "container mx-auto max-w-6xl px-4",
    isCenter ? "flex flex-col items-center text-center"
             : "flex flex-col items-start text-left",
  ]}>

    <!-- Eyebrow -->
    <p class="text-xs font-semibold uppercase tracking-widest mb-2.5" style="color:var(--color-gold-2);letter-spacing:0.12em;">
      {eyebrow}
    </p>

    <!-- Headline -->
    <h2 class="font-heading font-bold text-2xl md:text-3xl leading-tight mb-3 max-w-2xl"
        style="color: white">
      {headline}
    </h2>

    <!-- Subline -->
    <p class="text-white/80 text-sm md:text-base mb-7 max-w-xl leading-relaxed">
      {subline}
    </p>

    <!-- Buttons -->
    <div class:list={["flex flex-wrap items-center gap-3 mb-8", isCenter && "justify-center"]}>
      <a
        href={ctaHref}
        class="px-5 py-2.5 rounded-lg font-bold text-sm swipe-to-dark"
      >
        {ctaLabel}
      </a>
      {cta2Label && (
        <a
          href={cta2Href}
          target={cta2Href?.startsWith('http') ? '_blank' : undefined}
          rel={cta2Href?.startsWith('http') ? 'noopener' : undefined}
          class="inline-flex items-center gap-1.5 text-sm font-semibold hover:text-white/80 transition-colors underline-offset-2 hover:underline"
          style="color:white"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          {cta2Label}
        </a>
      )}
    </div>

    <!-- Kontaktlinks: flex-col auf Mobile, flex-row ab sm -->
    {showContact && (
      <div class:list={[
        "flex flex-col sm:flex-row sm:flex-wrap gap-4 text-sm",
        isCenter && "sm:justify-center",
      ]}>

        <a
          href="tel:+4917661990534"
          class="flex items-center gap-2.5 font-medium hover:text-accent transition-colors"
           style="color:white"
        >
          <SvgIcon icon={IconPhone} class="w-6 h-6 shrink-0 text-accent" />
          0176 61990534
        </a>

        <a
          href="https://wa.me/4917661990534"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2.5 font-medium hover:text-accent transition-colors"
           style="color:white"
        >
          <SvgIcon icon={IconWhatsApp} class="w-6 h-6 shrink-0 text-accent" />
          WhatsApp schreiben
        </a>

        <a
          href="https://www.instagram.com/circle_of_life_jiujitsu"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2.5 font-medium hover:text-accent transition-colors"
           style="color:white"
        >
          <SvgIcon icon={IconInstagram} class="w-6 h-6 shrink-0 text-accent" />
          Folge uns auf Instagram
        </a>

      </div>
    )}

  </div>
</div>
