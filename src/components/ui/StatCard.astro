---
import SvgIcon from './SvgIcon.astro';

interface Props {
  value: string;
  label: string;
  icon?: string;   // raw SVG string from src/icons/index.ts
  delay?: number;
  light?: boolean;
}

const { value, label, icon, delay = 0, light = false } = Astro.props;
---

<div
  class:list={['stat-card', { 'stat-card--light': light }]}
  data-aos="zoom-in"
  data-aos-delay={delay}
>
  {icon && (
    <div class="stat-card__icon">
      <SvgIcon icon={icon} class="w-6 h-6" />
    </div>
  )}
  <div class="stat-card__value">{value}</div>
  <div class="stat-card__label">{label}</div>
</div>
