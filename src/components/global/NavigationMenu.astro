---
import logo from '@/assets/images/JiuJitsuLogo.svg';

interface Props {
  currentPath?: string;
}

const { currentPath = Astro.url.pathname } = Astro.props;

const isActive = (path: string) =>
  currentPath === path || currentPath.startsWith(path + '/');

const kursLinks = [
  { href: '/bjj',            label: 'BJJ (Gi)' },
  { href: '/grappling',      label: 'No-Gi Grappling' },
  { href: '/kinder',         label: 'Kinder BJJ' },
  { href: '/fitness',        label: 'Fitness & Conditioning' },
  { href: '/zirkeltraining', label: 'Zirkeltraining' },
];

const kursActive =
  kursLinks.some(({ href }) => isActive(href)) || isActive('/kursangebot');
---

<a class="skip-link" href="#main-content">Zum Inhalt springen</a>

<nav
  id="main-nav"
  class="sticky top-0 z-50 bg-surface-dark border-b border-white/10 transition-transform duration-300"
  aria-label="Hauptnavigation"
>
  <div class="container mx-auto max-w-6xl px-4">

    <!-- ── Top bar: Logo + Desktop Nav + Hamburger ── -->
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 shrink-0 self-stretch py-2" title="Zur Startseite">
        <img
          src={logo.src}
          alt="Circle of Life BJJ"
          loading="eager"
          fetchpriority="high"
          class="nav-logo w-auto object-contain"
        />
        <span class="font-heading font-semibold text-white hidden sm:block text-sm whitespace-nowrap">
          Circle of Life
        </span>
      </a>

      <!-- Desktop nav links (hidden on mobile) -->
      <div class="hidden md:flex md:items-center md:gap-1">
        <ul class="flex items-center gap-1 text-sm font-medium">

          <li>
            <a
              href="/ueber-uns"
              class:list={[
                "block px-3 py-2 rounded-lg transition-colors",
                isActive('/ueber-uns')
                  ? "text-accent bg-surface-dark-raised"
                  : "text-white hover:bg-surface-dark-raised",
              ]}
            >
              Über uns
            </a>
          </li>

          <!-- Kursangebot dropdown (Flowbite hover dropdown — desktop only) -->
          <li class="relative">
            <button
              id="kursangebot-btn"
              data-dropdown-toggle="kursangebot-dropdown"
              data-dropdown-trigger="hover"
              type="button"
              class:list={[
                "flex items-center gap-1 px-3 py-2 rounded-lg transition-colors",
                kursActive
                  ? "text-accent bg-surface-dark-raised"
                  : "text-white hover:bg-surface-dark-raised",
              ]}
            >
              Kursangebot
              <svg class="w-2.5 h-2.5" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m1 1 4 4 4-4"/>
              </svg>
            </button>

            <div
              id="kursangebot-dropdown"
              class="z-50 hidden bg-surface-dark-raised divide-y divide-white/10 rounded-xl shadow-lg w-52 border border-white/10"
            >
              <ul class="py-2 text-sm" aria-labelledby="kursangebot-btn">
                <li>
                  <a
                    href="/kursangebot"
                    class:list={[
                      "block px-4 py-2 transition-colors",
                      isActive('/kursangebot')
                        ? "text-accent bg-surface-dark"
                        : "text-white hover:bg-surface-dark",
                    ]}
                  >
                    Alle Kurse
                  </a>
                </li>
                {kursLinks.map(item => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        "block px-4 py-2 transition-colors",
                        isActive(item.href)
                          ? "text-accent bg-surface-dark"
                          : "text-white hover:bg-surface-dark",
                      ]}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </li>

          {[
            { href: '/#kursplan', label: 'Kursplan' },
            { href: '/#preise',   label: 'Preise' },
          ].map(item => (
            <li>
              <a
                href={item.href}
                class="block px-3 py-2 rounded-lg text-white hover:bg-surface-dark-raised transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))}

          <li class="ms-2">
            <a
              href="/#probetraining"
              class="block px-4 py-2 rounded-lg bg-accent text-primary font-bold text-sm text-center hover:bg-accent-muted transition-colors"
            >
              Probetraining sichern
            </a>
          </li>

        </ul>
      </div>

      <!-- Hamburger (mobile only) -->
      <button
        id="nav-hamburger"
        type="button"
        class="md:hidden p-2 rounded-lg text-white hover:bg-surface-dark-raised transition-colors"
        aria-label="Menü öffnen"
        aria-expanded="false"
      >
        <svg id="icon-open" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>

    </div>
    <!-- ── End top bar ── -->

    <!-- ── Mobile menu — fixed unter der Navbar ── -->
    <div
      id="navbar-dropdown"
      class="hidden fixed left-0 right-0 z-40 md:hidden
             bg-surface-dark border-b border-white/10 shadow-lg"
      style="top: 64px"
    >
      <!-- Mobile menu logo -->
      <div class="flex items-center gap-3 px-3 py-3 border-b border-white/10 mb-2">
        <img
          src={logo.src}
          alt="Circle of Life BJJ"
          class="h-9 w-auto object-contain"
        />
        <span class="font-heading font-semibold text-white text-sm">Circle of Life</span>
      </div>

      <ul class="flex flex-col gap-0.5 px-4 pb-4 max-h-[80vh] overflow-y-auto">

        <li>
          <a href="/" class="mobile-link">Startseite</a>
        </li>

        <li>
          <a href="/ueber-uns" class="mobile-link">Über uns</a>
        </li>

        <li>
          <p class="px-3 pt-3 pb-1 text-xs font-semibold uppercase tracking-widest text-white/40">
            Kursangebot
          </p>
          <ul>
            <li><a href="/kursangebot"    class="mobile-link">Alle Kurse</a></li>
            {kursLinks.map(item => (
              <li><a href={item.href} class="mobile-link">{item.label}</a></li>
            ))}
          </ul>
        </li>

        <li><a href="/#kursplan" class="mobile-link">Kursplan</a></li>
        <li><a href="/#preise"   class="mobile-link">Preise</a></li>

        <li class="pt-3 px-1">
          <a
            href="/#probetraining"
            class="block w-full py-2.5 px-4 rounded-lg bg-accent text-primary
                   font-bold text-sm text-center hover:bg-accent-muted transition-colors"
          >
            Probetraining sichern
          </a>
        </li>

      </ul>
    </div>
    <!-- ── End mobile menu ── -->

  </div>
</nav>

<style>
  @reference "../../styles/theme.css";

  .skip-link {
    position: absolute; left: -999px; top: auto;
    width: 1px; height: 1px; overflow: hidden; z-index: 2000;
  }
  .skip-link:focus {
    left: 1rem; top: 1rem; width: auto; height: auto;
  }

  nav a:not(.bg-accent) {
    color: white !important;
  }
  nav button {
    color: white !important;
  }
  nav a.text-accent,
  nav button.text-accent {
    color: var(--accent) !important;
  }

  .nav-logo {
    height: 100% !important;
    display: block;
  }

  .mobile-link {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    transition: background-color 0.15s;
  }
  .mobile-link:hover {
    background-color: var(--color-surface-dark-raised);
  }
</style>

<script>
  function initMobileMenu() {
    const hamburger = document.getElementById('nav-hamburger')
    const menu      = document.getElementById('navbar-dropdown')
    const iconOpen  = document.getElementById('icon-open')
    const iconClose = document.getElementById('icon-close')

    if (!hamburger || !menu) return

    hamburger.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden')

      menu.classList.toggle('hidden', isOpen)
      iconOpen?.classList.toggle('hidden', !isOpen)
      iconClose?.classList.toggle('hidden', isOpen)
      hamburger.setAttribute('aria-expanded', String(!isOpen))
    })

    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        menu.classList.add('hidden')
        iconOpen?.classList.remove('hidden')
        iconClose?.classList.add('hidden')
        hamburger.setAttribute('aria-expanded', 'false')
      })
    })
  }

  document.addEventListener('astro:page-load', initMobileMenu)
  document.addEventListener('DOMContentLoaded', initMobileMenu)
</script>

<script>
  const nav = document.getElementById('main-nav');
  let lastY = window.scrollY;

  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    const isMobile = window.innerWidth < 768;
    if (isMobile && y > lastY && y > 80) {
      nav?.classList.add('-translate-y-full');
    } else {
      nav?.classList.remove('-translate-y-full');
    }
    lastY = y;
  }, { passive: true });
</script>
