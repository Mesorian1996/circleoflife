---
const workerUrl = import.meta.env.PUBLIC_CONTACT_WORKER_URL ?? '';
const kursOptions = [
  'Erwachsenen BJJ',
  'Kinder BJJ',
  'Zirkeltraining',
];

const fieldClass = 'w-full rounded-lg border border-border bg-white px-3 py-2.5 text-sm text-text font-sans outline-none transition-[border-color,box-shadow] duration-150 focus:border-accent focus:ring-2 focus:ring-accent/20';
const labelClass = 'block text-sm font-semibold text-text mb-1';
---

<form
  id="probetraining-form"
  data-action={workerUrl}
  class="space-y-5"
  novalidate
  aria-label="Probetraining anfragen"
>

  <!-- Honeypot Spam-Schutz -->
  <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

  <!-- Anrede -->
  <div>
    <label class={labelClass} for="anrede">Anrede</label>
    <select id="anrede" name="anrede" class={fieldClass}>
      <option value="">Bitte wählen</option>
      <option value="Herr">Herr</option>
      <option value="Frau">Frau</option>
      <option value="Divers">Divers</option>
    </select>
  </div>

  <!-- Name row -->
  <div class="grid grid-cols-2 gap-4">
    <div>
      <label class={labelClass} for="vorname">Vorname <span class="text-red-500">*</span></label>
      <input type="text" id="vorname" name="vorname" required autocomplete="given-name" class={fieldClass} placeholder="Max" />
    </div>
    <div>
      <label class={labelClass} for="nachname">Nachname <span class="text-red-500">*</span></label>
      <input type="text" id="nachname" name="nachname" required autocomplete="family-name" class={fieldClass} placeholder="Mustermann" />
    </div>
  </div>

  <!-- Telefon -->
  <div>
    <label class={labelClass} for="phone">Telefon</label>
    <input type="tel" id="phone" name="phone" autocomplete="tel" class={fieldClass} placeholder="0176 12345678" />
  </div>

  <!-- E-Mail -->
  <div>
    <label class={labelClass} for="email">E-Mail <span class="text-red-500">*</span></label>
    <input type="email" id="email" name="email" required autocomplete="email" class={fieldClass} placeholder="max@beispiel.de" />
  </div>

  <!-- Kursauswahl -->
  <div>
    <label class={labelClass} for="kurs">Interesse an</label>
    <select id="kurs" name="kurs" class={fieldClass}>
      <option value="">Bitte wählen</option>
      {kursOptions.map((o) => <option value={o}>{o}</option>)}
    </select>
  </div>

  <!-- Nachricht -->
  <div>
    <label class={labelClass} for="message">Nachricht (optional)</label>
    <textarea
      id="message"
      name="message"
      rows="4"
      class={`${fieldClass} resize-y min-h-[100px]`}
      placeholder="Hast du Fragen oder möchtest du uns etwas mitteilen?"
    ></textarea>
  </div>

  <!-- Error -->
  <div
    id="form-error"
    class="hidden rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"
    role="alert"
  ></div>

  <!-- Success -->
  <div
    id="form-success"
    class="hidden rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700"
    role="status"
  >
    <strong>Oss! 🙏</strong> Deine Anfrage ist eingegangen. Wir melden uns innerhalb von 24 Stunden.
  </div>

  <!-- Submit -->
  <button
    type="submit"
    id="form-submit"
    class="w-full rounded-xl bg-accent py-3 text-sm font-bold text-primary transition-colors duration-200 hover:bg-primary hover:text-white disabled:opacity-60"
  >
    <span id="btn-label">Probetraining anfragen</span>
    <span id="btn-loading" class="hidden">Wird gesendet…</span>
  </button>

  <p class="text-center text-xs text-text-faint mt-2">
    Kostenlos &amp; unverbindlich · Antwort innerhalb von 24&nbsp;h
  </p>
</form>

<script is:inline>
(function () {
  var form       = document.getElementById('probetraining-form');
  if (!form) return;
  var submitBtn  = document.getElementById('form-submit');
  var btnLabel   = document.getElementById('btn-label');
  var btnLoading = document.getElementById('btn-loading');
  var errorDiv   = document.getElementById('form-error');
  var successDiv = document.getElementById('form-success');

  function setLoading(on) {
    submitBtn.disabled = on;
    btnLabel.classList.toggle('hidden', on);
    btnLoading.classList.toggle('hidden', !on);
  }

  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    errorDiv.classList.add('hidden');
    successDiv.classList.add('hidden');

    var vorname = form.querySelector('#vorname').value.trim();
    var nachname = form.querySelector('#nachname').value.trim();
    var email = form.querySelector('#email').value.trim();

    if (!vorname && !nachname) {
      errorDiv.textContent = 'Bitte gib deinen Namen an.';
      errorDiv.classList.remove('hidden');
      return;
    }
    if (!email) {
      errorDiv.textContent = 'Bitte gib deine E-Mail-Adresse an.';
      errorDiv.classList.remove('hidden');
      return;
    }

    setLoading(true);
    try {
      var res = await fetch(form.dataset.action, {
        method: 'POST',
        body: new FormData(form),
      });
      var json = await res.json();
      if (json.success) {
        successDiv.classList.remove('hidden');
        form.reset();
      } else {
        errorDiv.textContent = json.message || 'Ein Fehler ist aufgetreten. Bitte versuche es erneut.';
        errorDiv.classList.remove('hidden');
      }
    } catch {
      errorDiv.textContent = 'Verbindung fehlgeschlagen. Bitte versuche es später erneut.';
      errorDiv.classList.remove('hidden');
    } finally {
      setLoading(false);
    }
  });
})();
</script>
