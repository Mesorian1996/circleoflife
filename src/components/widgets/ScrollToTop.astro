<div class="fab-root" id="fabRoot" role="complementary" aria-label="Schnellaktionen">

  <!-- Sub-items (stacked bottom-to-top: scroll, anfrage, anrufen) -->
  <div class="fab-items" id="fabItems" aria-hidden="true">

    <div class="fab-item">
      <span class="fab-item__label">Nach oben</span>
      <button class="fab-item__btn" id="fabScrollTop" type="button" aria-label="Zum Seitenanfang scrollen">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 19V5M5 12l7-7 7 7"/>
        </svg>
      </button>
    </div>

    <div class="fab-item">
      <span class="fab-item__label">Anfrage stellen</span>
      <a class="fab-item__btn" href="#probetraining" aria-label="Probetraining anfragen">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </a>
    </div>

    <div class="fab-item">
      <span class="fab-item__label">Anrufen</span>
      <a class="fab-item__btn" href="tel:+4917661990534" aria-label="Jetzt anrufen">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.26h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.9a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16.9"/>
        </svg>
      </a>
    </div>

  </div>

  <!-- Trigger "+" button -->
  <button class="fab-trigger" id="fabTrigger" type="button"
    aria-label="Schnellaktionen öffnen" aria-expanded="false" aria-controls="fabItems">
    <svg class="fab-plus-icon" xmlns="http://www.w3.org/2000/svg"
      width="22" height="22" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 5v14M5 12h14"/>
    </svg>
  </button>

</div>

<style>
  .fab-root {
    position: fixed;
    bottom: 28px;
    right: 24px;
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s ease;
  }
  .fab-root.visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* Sub-items wrapper */
  .fab-items {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
  }

  /* Individual item row */
  .fab-item {
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0;
    transform: translateY(10px) scale(0.88);
    pointer-events: none;
    transition: opacity 0.24s ease, transform 0.28s var(--easing-spring, cubic-bezier(0.34,1.56,0.64,1));
  }
  .fab-root.is-open .fab-item {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
  .fab-root.is-open .fab-item:nth-child(1) { transition-delay: 0ms; }
  .fab-root.is-open .fab-item:nth-child(2) { transition-delay: 55ms; }
  .fab-root.is-open .fab-item:nth-child(3) { transition-delay: 110ms; }

  /* Pill label */
  .fab-item__label {
    background: var(--color-primary, #14182b);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    padding: 0.28em 0.85em;
    border-radius: 2em;
    white-space: nowrap;
    box-shadow: 0 2px 10px rgba(20,24,43,0.22);
    opacity: 0;
    transform: translateX(6px);
    transition: opacity 0.2s ease, transform 0.22s ease;
    transition-delay: 0.12s;
    user-select: none;
  }
  .fab-root.is-open .fab-item__label {
    opacity: 1;
    transform: translateX(0);
  }

  /* Small circle buttons */
  .fab-item__btn {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: #fff;
    border: 1.5px solid var(--color-border, #e4e6ec);
    box-shadow: 0 3px 12px rgba(20,24,43,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    outline: none;
    color: var(--color-primary, #14182b);
    text-decoration: none;
    transition: background 0.18s ease, border-color 0.18s ease, transform 0.16s var(--easing-spring, cubic-bezier(0.34,1.56,0.64,1));
  }
  .fab-item__btn:hover {
    background: var(--color-accent-light, #f5efe3);
    border-color: var(--color-accent, #bfa24a);
    transform: scale(1.1);
  }
  .fab-item__btn:focus-visible {
    outline: 2px solid var(--color-accent, #bfa24a);
    outline-offset: 2px;
  }

  /* Main trigger button */
  .fab-trigger {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--color-primary, #14182b);
    border: 2px solid var(--color-accent, #bfa24a);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    outline: none;
    box-shadow: 0 4px 20px rgba(20,24,43,0.28), 0 0 0 0 rgba(191,162,74,0);
    transition: transform 0.2s var(--easing-spring, cubic-bezier(0.34,1.56,0.64,1)),
                background 0.18s ease,
                box-shadow 0.22s ease;
  }
  .fab-trigger:hover {
    background: var(--color-dark-raised, #1c2040);
    transform: scale(1.07);
    box-shadow: 0 6px 24px rgba(20,24,43,0.34), 0 0 0 4px rgba(191,162,74,0.18);
  }
  .fab-trigger:focus-visible {
    outline: 2px solid var(--color-accent, #bfa24a);
    outline-offset: 3px;
  }
  .fab-root.is-open .fab-trigger {
    background: var(--color-dark-raised, #1c2040);
  }

  /* + rotates to × */
  .fab-plus-icon {
    transition: transform 0.32s var(--easing-spring, cubic-bezier(0.34,1.56,0.64,1));
  }
  .fab-root.is-open .fab-plus-icon {
    transform: rotate(45deg);
  }
</style>

<script is:inline>
(function () {
  var root    = document.getElementById('fabRoot');
  var trigger = document.getElementById('fabTrigger');
  var items   = document.getElementById('fabItems');
  var scrollBtn = document.getElementById('fabScrollTop');

  if (!root || !trigger) return;

  /* Show / hide on scroll */
  window.addEventListener('scroll', function () {
    root.classList.toggle('visible', window.scrollY > 220);
  }, { passive: true });

  /* Toggle open/close */
  trigger.addEventListener('click', function (e) {
    e.stopPropagation();
    var isOpen = root.classList.toggle('is-open');
    trigger.setAttribute('aria-expanded', String(isOpen));
    if (items) items.setAttribute('aria-hidden', String(!isOpen));
  });

  /* Scroll to top */
  if (scrollBtn) {
    scrollBtn.addEventListener('click', function () {
      window.scrollTo({ top: 0, behavior: 'smooth' });
      root.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
    });
  }

  /* Close on outside click */
  document.addEventListener('click', function () {
    if (root.classList.contains('is-open')) {
      root.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
      if (items) items.setAttribute('aria-hidden', 'true');
    }
  });

  /* Close after navigating via anchor links */
  root.querySelectorAll('.fab-item__btn[href]').forEach(function (el) {
    el.addEventListener('click', function () {
      root.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
    });
  });
})();
</script>
