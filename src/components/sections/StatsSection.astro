---
const stats = [
  { value: '60+',         label: 'aktive Mitglieder' },
  { value: '6×/Woche',   label: 'Training' },
  { value: '1',          label: 'Headcoach' },
  { value: 'Top Hygiene', label: 'Desinfizierte Mattenfläche' },
];
---

<section class="cv-section cv-section--compact bg-linear-to-r from-gold to-gold-2 py-12" aria-label="Statistiken">
  <div class="container">
    <dl class="grid grid-cols-2 gap-8 sm:grid-cols-4 text-center">
      {stats.map((s, i) => (
        <div data-aos="zoom-in" data-aos-delay={i * 150}>
          <dt class="text-4xl font-extrabold text-primary">{s.value}</dt>
          <dd class="mt-1 text-sm font-medium text-primary/70">{s.label}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
