---
import SectionHeader from '../ui/SectionHeader.astro';

interface Step {
  number: string;
  title: string;
  desc: string;
}

const steps: Step[] = [
  {
    number: '01',
    title: 'Kontakt aufnehmen',
    desc: 'Schreib uns per Formular, WhatsApp oder ruf einfach an. Wir antworten innerhalb von 24 Stunden und stimmen deinen Einstiegstermin ab.',
  },
  {
    number: '02',
    title: 'Kostenloses Probetraining',
    desc: 'Komm in Sportkleidung vorbei. Flip-Flops mitbringen – alles andere erklären wir dir vor Ort. Kein Gi nötig, kein Vorwissen erforderlich.',
  },
  {
    number: '03',
    title: 'Teil der Community werden',
    desc: 'Nach dem Probetraining entscheidest du, ob BJJ für dich ist. Bei Ja: Mitgliedschaft abschließen und sofort Teil der Circle of Life Familie werden.',
  },
];
---

<section class="cv-section" style="padding:2.5em 0;">
  <div class="container">
    <SectionHeader
      title="Dein Einstieg in 3 Schritten"
      subtitle="Vom ersten Kontakt bis auf die Matte – einfacher geht's nicht."
    />

    <div class="prozess-grid" data-aos="fade-up" data-aos-delay="50">
      {steps.map((step, i) => (
        <div class="prozess-step" data-aos="fade-up" data-aos-delay={i * 120}>
          <div class="prozess-step__number">{step.number}</div>
          {i < steps.length - 1 && (
            <div class="prozess-connector" aria-hidden="true"></div>
          )}
          <h3 class="prozess-step__title">{step.title}</h3>
          <p class="prozess-step__desc">{step.desc}</p>
        </div>
      ))}
    </div>

    <div style="text-align:center;margin-top:2rem;" data-aos="fade-up" data-aos-delay="400">
      <a class="btn-brand btn-lg" href="/#probetraining">Jetzt Probetraining anfragen</a>
    </div>
  </div>
</section>
