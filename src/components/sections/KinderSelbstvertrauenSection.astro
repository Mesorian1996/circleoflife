---
const benefits = [
  {
    title: 'Selbstvertrauen',
    desc:  'Kinder die sich körperlich kompetent fühlen, treten in jeder Situation selbstbewusster auf – auf dem Schulhof wie im Alltag.',
  },
  {
    title: 'Anti-Bullying',
    desc:  'Sie lernen Konflikte zu deeskalieren, klare Grenzen zu setzen und – wenn nötig – sich selbst zu schützen.',
  },
  {
    title: 'Konzentration',
    desc:  'Technisches Training schult Fokus, Geduld und die Fähigkeit, schrittweise an Aufgaben zu arbeiten.',
  },
  {
    title: 'Soziale Kompetenz',
    desc:  'Respekt, Fairness und Teamgeist entstehen auf der Matte – und übertragen sich auf Schule und Familie.',
  },
  {
    title: 'Körpergefühl',
    desc:  'Koordination, Gleichgewicht und Beweglichkeit werden spielerisch aufgebaut und bilden ein starkes Fundament.',
  },
]
---

<section class="bg-surface-dark py-16 md:py-20" data-aos="fade-up">
  <div class="container mx-auto max-w-6xl px-4">

    <div class="grid grid-cols-1 gap-10 md:grid-cols-2 md:gap-16">

      <!-- Left: Text -->
      <div class="flex flex-col justify-center">
        <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-3">
          Warum Kinder-BJJ?
        </p>
        <h2 class="font-heading font-bold text-3xl md:text-4xl leading-tight mb-5"
            style="color: white">
          Mehr als Kampfsport – ein Fundament fürs Leben
        </h2>
        <p class="text-white/80 text-base leading-relaxed mb-4">
          Kinder-BJJ bei Circle of Life stärkt nicht nur den Körper. Es gibt Kindern die
          Werkzeuge um selbstbewusst, fokussiert und respektvoll durch den Alltag zu gehen.
        </p>
        <p class="text-white/80 text-base leading-relaxed">
          Unser Training ist spielerisch aufgebaut, strukturiert begleitet und auf die
          Entwicklungsphase von 6- bis 13-Jährigen abgestimmt. Kein Ego, keine Härte –
          nur echtes Wachstum in kleinen Gruppen.
        </p>
      </div>

      <!-- Right: Benefit list -->
      <div class="flex flex-col gap-4">
        {benefits.map((b) => (
          <div class="flex items-start gap-4 rounded-xl bg-white/5 border border-white/10 px-5 py-4">
            <span class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-accent"></span>
            <div>
              <p class="font-semibold text-white text-sm mb-0.5">{b.title}</p>
              <p class="text-white/65 text-sm leading-relaxed">{b.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>

    <!-- Bottom CTA -->
    <div class="mt-12 flex flex-wrap gap-3">
      <a
        href="/#probetraining"
        class="px-6 py-3 rounded-lg bg-gold text-primary font-bold text-sm hover:bg-primary hover:text-white transition-colors"
      >
        Kostenloses Probetraining sichern
      </a>
      <a
        href="tel:+4917661990534"
        class="px-6 py-3 rounded-lg border-2 border-white text-white font-semibold text-sm hover:bg-white hover:text-primary transition-colors"
      >
        0176 61990534 anrufen
      </a>
    </div>

  </div>
</section>
