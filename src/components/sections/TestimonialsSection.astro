---
import { testimonials, googleReviewsUrl } from '@/data/testimonials'
import SectionHeader from '@/components/ui/SectionHeader.astro'
---

<section class="py-16 md:py-24 overflow-hidden" style="background: var(--color-surface);">
  <div class="container mx-auto max-w-6xl px-4">

    <SectionHeader
      eyebrow="Google Bewertungen"
      title="Was unsere Mitglieder sagen"
      subtitle="Echte Erfahrungen von Menschen aus Ludwigshafen, Mannheim und der Region."
      align="center"
    />

    <div class="testimonials-masonry mt-12" data-aos="fade-up">
      {testimonials.map(t => (
        <figure class="testimonial-card">

          <div class="flex gap-0.5 mb-3">
            {Array.from({ length: t.rating }).map(() => (
              <svg class="w-3.5 h-3.5 text-accent" fill="currentColor" viewBox="0 0 22 20" aria-hidden="true">
                <path d="M20.924 7.625a1.523 1.523 0 0 0-1.238-1.044l-5.051-.734-2.259-4.577a1.534 1.534 0 0 0-2.752 0L7.365 5.847l-5.051.734A1.535 1.535 0 0 0 1.463 9.2l3.656 3.563-.863 5.031a1.532 1.532 0 0 0 2.226 1.616L11 17.033l4.518 2.375a1.534 1.534 0 0 0 2.226-1.617l-.863-5.03L20.537 9.2a1.523 1.523 0 0 0 .387-1.575Z"/>
              </svg>
            ))}
          </div>

          <blockquote class="mb-4">
            <p class="text-text-muted text-sm leading-relaxed">„{t.text}"</p>
          </blockquote>

          <figcaption class="flex items-center justify-between pt-3 border-t border-border">
            <div>
              <p class="font-semibold text-text text-sm">{t.name}</p>
              {t.role && <p class="text-xs text-text-faint">{t.role}</p>}
            </div>
            <div class="flex items-center gap-1.5 text-xs text-text-faint">
              <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              <span>{t.ago}</span>
            </div>
          </figcaption>

        </figure>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a
        href={googleReviewsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm text-text-muted hover:text-accent transition-colors"
      >
        Alle Bewertungen auf Google ansehen →
      </a>
    </div>

  </div>
</section>

<style>
  .testimonials-masonry {
    columns: 1;
    column-gap: 1.5rem;
  }
  @media (min-width: 640px) {
    .testimonials-masonry { columns: 2; }
  }
  @media (min-width: 1024px) {
    .testimonials-masonry { columns: 3; }
  }

  .testimonial-card {
    break-inside: avoid;
    background: #fff;
    border-radius: 0.875rem;
    border: 1px solid var(--color-border);
    border-top: 2.5px solid var(--color-accent);
    box-shadow: var(--shadow-card);
    padding: 1.35rem 1.25rem;
    margin-bottom: 1.5rem;
    display: block;
    transition: box-shadow 0.22s ease, transform 0.18s var(--easing-spring), border-top-color 0.22s ease;
  }
  .testimonial-card:hover {
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-3px);
    border-top-color: var(--color-gold);
  }
</style>
