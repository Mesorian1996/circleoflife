---
import SectionHeader from '../ui/SectionHeader.astro';
import KursBadge from '../ui/KursBadge.astro';
import { ALL_DAYS, kurse, kursStyles, getSlots, findKurs, getActiveDays } from '../../data/kursplan';

const slots      = getSlots();
const activeDays = getActiveDays();
---

<section id="kursplan" class="cv-section" style="padding:2.5em 0;">
  <div class="container">
    <SectionHeader
      title="Kursplan"
      subtitle="6× pro Woche Training für Erwachsene, 2× für Kinder. Jede Einheit: Aufwärmen, Mobility, Technikdrills & Sparring."
    />

    <!-- ── Desktop table (≥ 700 px) ── -->
    <div class="wochen-card kursplan-desktop" data-aos="fade-up" data-aos-delay="100">
      <table class="wochen-table">
        <thead>
          <tr>
            <th>Tag</th>
            {slots.map(s => <th>{s.label}</th>)}
          </tr>
        </thead>
        <tbody>
          {ALL_DAYS.map(tag => (
            <tr>
              <td>{tag}</td>
              {slots.map(slot => {
                const k = findKurs(tag, slot.start);
                return (
                  <td>
                    {k && (
                      k.href
                        ? <a href={k.href} class="kurs-link"><KursBadge typ={k.typ} label={k.titel} /></a>
                        : <KursBadge typ={k.typ} label={k.titel} />
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>

      <!-- Legend -->
      <div class="kursplan-legend">
        {(['gi', 'nogi', 'kids'] as const).map(typ => (
          <span>
            <span class="dot" style={`background:${kursStyles[typ].dot};`}></span>
            {kursStyles[typ].label}
          </span>
        ))}
        <span>
          <span class="dot" style="background:#0d9488;"></span>
          Zirkel Mamas
        </span>
        <span>
          <span class="dot" style="background:#5eead4;"></span>
          Zirkel 60+
        </span>
      </div>

      <div class="kursplan-notes">
        <p style="margin:.25rem 0;">Open Mats finden außerhalb der regulären Trainingszeiten nach Absprache oder Ankündigung statt.</p>
        <p style="margin:.25rem 0;">Bitte ca. 15 Min. vorher da sein; Flip-Flops mitbringen. Duschen stehen zur Verfügung.</p>
      </div>
    </div>

    <!-- ── Mobile tabs (< 700 px) — Preline hs-tab ── -->
    <div class="kursplan-tabs" data-aos="fade-up" data-aos-delay="100">

      <!-- Tab nav -->
      <nav class="flex flex-wrap gap-2 mb-5" aria-label="Trainingstage" role="tablist">
        {activeDays.map((tag, i) => (
          <button
            type="button"
            id={`kp-tab-${tag}`}
            data-hs-tab={`#kp-panel-${tag}`}
            aria-controls={`kp-panel-${tag}`}
            data-day={tag}
            role="tab"
            class:list={[
              'kp-tab',
              'hs-tab-active:bg-accent hs-tab-active:border-accent hs-tab-active:text-primary',
              'rounded-full border border-border bg-white px-4 py-1.5 text-sm font-semibold text-text-muted',
              'transition-all duration-150 hover:border-accent hover:text-accent outline-none',
              'focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-1',
              { active: i === 0 },
            ]}
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {tag}
          </button>
        ))}
      </nav>

      <!-- Tab panels -->
      {activeDays.map((tag, i) => {
        const dayCourses = kurse.filter(k => k.tag === tag);
        return (
          <div
            id={`kp-panel-${tag}`}
            role="tabpanel"
            aria-labelledby={`kp-tab-${tag}`}
            class:list={[i !== 0 && 'hidden']}
          >
            <div class="flex flex-col gap-3">
              {dayCourses.map(k => (
                <div class="flex items-center justify-between gap-4 rounded-xl border border-border bg-white px-4 py-3 shadow-(--shadow-card)">
                  <span class="text-sm font-semibold text-text-muted">{k.start} – {k.end}</span>
                  {k.href
                    ? <a href={k.href} class="kurs-link"><KursBadge typ={k.typ} label={k.titel} /></a>
                    : <KursBadge typ={k.typ} label={k.titel} />
                  }
                </div>
              ))}
            </div>
          </div>
        );
      })}

      <!-- Notes -->
      <p class="mt-4 text-sm text-text-faint">Bitte ca. 15 Min. vorher da sein; Flip-Flops mitbringen.</p>
    </div>
  </div>
</section>

<script is:inline>
(function () {
  var tabs   = document.querySelectorAll('[data-hs-tab]');
  var panels = document.querySelectorAll('[role="tabpanel"]');
  if (!tabs.length) return;

  function activate(selectedTab) {
    var targetId = selectedTab.getAttribute('data-hs-tab').replace('#', '');
    tabs.forEach(function (t) {
      var active = t === selectedTab;
      t.classList.toggle('active', active);
      t.setAttribute('aria-selected', active ? 'true' : 'false');
    });
    panels.forEach(function (p) {
      var active = p.id === targetId;
      p.classList.toggle('hidden', !active);
    });
  }

  tabs.forEach(function (btn) {
    btn.addEventListener('click', function () { activate(btn); });
  });

  // Highlight current weekday tab
  var dayMap = ['So', 'Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa'];
  var today  = dayMap[new Date().getDay()];
  var todayTab = document.querySelector('.kp-tab[data-day="' + today + '"]');
  if (todayTab) {
    // Add today marker dot
    if (!todayTab.querySelector('.today-dot')) {
      var dot = document.createElement('span');
      dot.className = 'today-dot';
      dot.style.cssText = 'display:inline-block;width:6px;height:6px;background:currentColor;border-radius:50%;margin-left:5px;vertical-align:middle;opacity:0.7;';
      todayTab.appendChild(dot);
    }
    // Auto-activate today's tab if it exists and no user interaction yet
    activate(todayTab);
  }
})();
</script>
