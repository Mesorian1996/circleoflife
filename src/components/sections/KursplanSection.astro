---
import SectionHeader from '../ui/SectionHeader.astro';
import { ALL_DAYS, kurse, kursStyles, getSlots, findKurs, getActiveDays } from '../../data/kursplan';

const slots      = getSlots();
const activeDays = getActiveDays();

// Fitness aus der Legende ausblenden — kein aktiver Kurs
const legendTypes = (Object.keys(kursStyles) as (keyof typeof kursStyles)[]).filter(t => t !== 'fitness');
---

<section id="kursplan" class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <SectionHeader
      title="Kursplan"
      subtitle="Gi BJJ, No-Gi Grappling, Kinder BJJ (6–13 Jahre), Fitness und Conditioning sowie Zirkeltraining für Mamas und Senioren — alles in unserer Kampfsportschule in Ludwigshafen Ruchheim. Unsere Mitglieder kommen aus Ludwigshafen, Mannheim, Frankenthal, Bad Dürkheim und der gesamten Rhein-Neckar-Region."
    />

    <!-- ── Desktop Grid (≥ lg) ── -->
    <div class="hidden lg:block overflow-hidden rounded-2xl border border-gray-100 shadow-sm" data-aos="fade-up">
      <div class="grid grid-cols-8 bg-gray-50 border-b border-gray-100">
        <div class="p-4 text-xs font-bold uppercase tracking-widest text-gray-400">Zeit</div>
        {ALL_DAYS.map(tag => (
          <div class="p-4 text-center font-bold text-gray-900 border-l border-gray-100 uppercase tracking-wider">{tag}</div>
        ))}
      </div>

      {slots.map(slot => (
        <div class="grid grid-cols-8 border-b border-gray-50 last:border-0">
          <div class="p-4 text-xs font-mono font-bold text-gray-700 flex items-center justify-center bg-gray-100/60">{slot.label}</div>
          {ALL_DAYS.map(tag => {
            const k = findKurs(tag, slot.start);
            const dot = k ? (kursStyles[k.typ]?.dot ?? '#bfa24a') : null;
            return (
              <div class="p-1.5 border-l border-gray-50 min-h-[90px] flex">
                {k && (
                  <div
                    class="w-full p-2.5 rounded-lg border-l-4 shadow-sm flex flex-col justify-center transition-transform hover:scale-[1.03]"
                    style={`border-color:${dot};background-color:${dot}15;`}
                  >
                    <p class="text-sm font-bold leading-tight" style={`color:${dot};`}>
                      {k.titel.replace('Erwachsenen ', '')}
                    </p>
                    <span class="text-[11px] mt-1 text-gray-500 font-medium uppercase tracking-tighter italic">{k.start}</span>
                  </div>
                )}
              </div>
            );
          })}
        </div>
      ))}
    </div>

    <!-- ── Mobile Tabs (< lg) ── -->
    <div class="lg:hidden">
      <div class="sticky top-0 z-30 -mx-4 px-4 bg-white/95 backdrop-blur-sm border-b border-gray-100 mb-6">
        <nav class="flex gap-2 py-4 overflow-x-auto no-scrollbar scroll-smooth" role="tablist">
          {activeDays.map((tag) => (
            <button
              type="button"
              id={`kp-tab-${tag}`}
              data-hs-tab={`#kp-panel-${tag}`}
              data-day={tag}
              class="kp-tab shrink-0 px-6 py-2 rounded-full text-sm font-bold transition-all border border-gray-200 text-gray-500 bg-white"
            >
              {tag}
            </button>
          ))}
        </nav>
      </div>

      <div class="space-y-4">
        {activeDays.map((tag, i) => {
          const dayCourses = kurse.filter(k => k.tag === tag);
          return (
            <div
              id={`kp-panel-${tag}`}
              role="tabpanel"
              class:list={[i !== 0 && 'hidden', 'animate-in fade-in slide-in-from-bottom-2 duration-300']}
            >
              <div class="grid gap-3">
                {dayCourses.map(k => {
                  const dot = kursStyles[k.typ]?.dot ?? '#bfa24a';
                  return (
                    <div
                      class="flex items-center gap-4 p-4 rounded-xl border border-gray-100 shadow-sm border-l-4"
                      style={`border-color:${dot};background-color:${dot}10;`}
                    >
                      <div class="flex flex-col min-w-[75px]">
                        <span class="text-sm font-black" style={`color:${dot};`}>{k.start}</span>
                        <span class="text-[10px] text-gray-400 font-medium uppercase">{k.end}</span>
                      </div>
                      <div class="flex-1">
                        <h4 class="font-bold text-gray-900 leading-tight">{k.titel.replace('Erwachsenen ', '')}</h4>
                        <p class="text-[11px] text-gray-500 font-semibold uppercase tracking-wide">{kursStyles[k.typ]?.label || 'Zirkeltraining'}</p>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- ── Legende (nur Desktop, ohne Fitness) ── -->
    <div class="hidden lg:flex mt-12 flex-wrap justify-center gap-6">
      {legendTypes.map(typ => (
        <div class="flex items-center gap-2 group cursor-default">
          <span class="w-3 h-3 rounded-full shadow-sm transition-transform group-hover:scale-125" style={`background:${kursStyles[typ].dot};`}></span>
          <span class="text-xs font-bold text-gray-500 uppercase tracking-widest">{kursStyles[typ].label}</span>
        </div>
      ))}
    </div>

    <div class="mt-10 max-w-2xl mx-auto">
      <p class="text-xs text-center text-gray-400 leading-relaxed italic">
        * Bitte ca. 15 Min. vor Trainingsbeginn erscheinen. Flip-Flops für den Gang von der Umkleide zur Matte sind Pflicht. Duschen stehen zur Verfügung.
      </p>
    </div>
  </div>
</section>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

  .kp-tab.active {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-primary);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-accent) 25%, transparent);
  }
</style>

<script is:inline>
(function () {
  var tabs   = document.querySelectorAll('.kp-tab');
  var panels = document.querySelectorAll('[role="tabpanel"]');
  if (!tabs.length) return;

  function activate(tab) {
    var targetId = tab.getAttribute('data-hs-tab').replace('#', '');
    tabs.forEach(function (t) {
      t.classList.toggle('active', t === tab);
      t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
    });
    panels.forEach(function (p) {
      p.classList.toggle('hidden', p.id !== targetId);
    });
  }

  tabs.forEach(function (btn) { btn.addEventListener('click', function () { activate(btn); }); });

  var dayMap   = ['So', 'Mo', 'Di', 'Mi', 'Do', 'Fr', 'Sa'];
  var today    = dayMap[new Date().getDay()];
  var todayTab = document.querySelector('.kp-tab[data-day="' + today + '"]');
  if (todayTab) {
    activate(todayTab);
    todayTab.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
  } else if (tabs.length) {
    activate(tabs[0]);
  }
})();
</script>
