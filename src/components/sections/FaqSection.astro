---
import { faqs, faqByPage } from '@/data/faq'
import AccordionItem       from '@/components/ui/AccordionItem.astro'
import SectionHeader       from '@/components/ui/SectionHeader.astro'

interface Props {
  page?: string
}
const { page } = Astro.props
const items = (page && faqByPage[page]) ? faqByPage[page] : faqs
---

<section id="faq" class="py-16 md:py-24 bg-surface" aria-labelledby="faq-heading">
  <div class="container mx-auto max-w-3xl px-4">

    <SectionHeader
      eyebrow="FAQ"
      title="Häufige Fragen"
      subtitle="Noch unsicher? Hier findest du Antworten auf die wichtigsten Fragen."
      align="center"
    />

    <!-- Flowbite Accordion: data-accordion="collapse" = immer nur 1 offen -->
    <div
      id="faq-accordion"
      data-accordion="collapse"
      class="mt-10 rounded-xl overflow-hidden border border-border shadow-(--shadow-card)"
      data-aos="fade-up"
      data-aos-delay="100"
    >
      {items.map((item, i) => (
        <AccordionItem
          id={item.id}
          frage={item.frage}
          antwort={item.antwort}
          open={item.open}
          last={i === items.length - 1}
        />
      ))}
    </div>

  </div>
</section>
