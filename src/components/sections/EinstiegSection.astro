---
import SectionHeader from '../ui/SectionHeader.astro';

const steps = [
  {
    number: '1',
    title: 'Probetraining anfragen',
    href: '#probetraining',
    desc: 'Erster Kontakt leicht gemacht: Formular ausfüllen, per Telefon anrufen oder eine WhatsApp-Nachricht schicken. Wir melden uns innerhalb von 24 Stunden und bestätigen deinen Termin für das kostenlose Probetraining.',
    delay: 0,
  },
  {
    number: '2',
    title: 'Probetraining absolvieren',
    href: undefined,
    desc: 'Komm einfach vorbei und erlebe dein erstes Training! Lerne unser Team, die Trainer und das Training im Gi und No-Gi kennen. Du bekommst einen realistischen Eindruck – kostenlos und unverbindlich.',
    delay: 150,
  },
  {
    number: '3',
    title: 'Dranbleiben & wachsen',
    href: undefined,
    desc: 'Nach dem Probetraining entscheidest du, ob du Teil unserer Community wirst. Mit regelmäßigem Training entwickelst du Technik, Fitness und Selbstvertrauen.',
    delay: 300,
  },
];
---

<section id="einstieg" class="cv-section" style="padding:3.5em 0; background:#faf7f3;">
  <div class="container">
    <SectionHeader
      title="Be a part of the Circle"
      subtitle={`Stärker werden – technisch, mental und als Team. Das ist unser Versprechen. Viele unserer Mitglieder kommen aus <strong>Ludwigshafen</strong>, <strong>Mannheim</strong>, <strong>Bad Dürkheim</strong> oder <strong>Frankenthal</strong>. Egal woher du kommst – sichere dir dein <a href="#probetraining" style="color:var(--color-accent-text);font-weight:700;text-decoration:underline;text-underline-offset:2px;">kostenloses Probetraining</a>.`}
    />

    <div class="einstieg-timeline" data-aos="fade-up">
      {steps.map((s) => (
        <div class="einstieg-step">
          <span class="einstieg-step__number">{s.number}</span>
          <div>
            <h3 class="einstieg-step__title">
              {s.href
                ? <a href={s.href} class="text-inherit no-underline hover:text-accent transition-colors">{s.title}</a>
                : s.title
              }
            </h3>
            <p class="einstieg-step__desc">{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
