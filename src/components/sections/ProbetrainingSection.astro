---
import SvgIcon from '../ui/SvgIcon.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import ProbetrainingForm from '../widgets/ProbetrainingForm.astro';
import {
  IconMapPin, IconPhone, IconEmail, IconInstagram, IconWhatsApp, IconParking,
} from '@/icons/index';

const contacts = [
  { icon: IconMapPin,    href: undefined,                                                              text: 'Circle of Life Jiu-Jitsu\nAm Herrschaftsweiher 17\n67071 Ludwigshafen am Rhein', label: 'Adresse' },
  { icon: IconPhone,     href: 'tel:+4917661990534',                                                  text: '0176 61990534',            label: 'Telefon' },
  { icon: IconEmail,     href: 'mailto:mail.circleoflife@gmx.de',                                     text: 'mail.circleoflife@gmx.de', label: 'E-Mail' },
  { icon: IconInstagram, href: 'https://www.instagram.com/circle_of_life_jiujitsu?igsh=MXVyMDNtdHRmNXoxZw==', text: 'circle_of_life_jiujitsu', label: 'Instagram', external: true },
  { icon: IconWhatsApp,  href: 'https://wa.me/4917661990534',                                         text: 'WhatsApp schreiben',       label: 'WhatsApp', external: true },
] as const;
---

<section id="probetraining" class="cv-section bg-surface" style="padding:2.5em 0;">
  <div class="container">
    <SectionHeader
      title="Kostenloses Probetraining"
      subtitle="Teste kostenlos, ob Brazilian Jiu-Jitsu oder Grappling als Kampfsport zu dir passt. Wir melden uns in der Regel innerhalb von 24h bei dir."
    />

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2 items-start">

      <!-- Form card -->
      <div
        class="rounded-2xl border border-border bg-white p-6 shadow-(--shadow-card)"
        data-aos="fade-up"
      >
        <ProbetrainingForm />
        <p class="mt-3 text-xs text-text-faint">
          Mit dem Absenden bestätige ich die Verarbeitung meiner Daten gemäß der
          <a href="/datenschutz" class="text-accent underline-offset-2 hover:underline">Datenschutzerklärung</a>.
        </p>
      </div>

      <!-- Contact card -->
      <div
        class="flex flex-col rounded-2xl border border-border bg-white p-6 shadow-(--shadow-card)"
        data-aos="fade-up"
        data-aos-delay="200"
        id="kontakt"
      >
        <h3 class="mb-5 text-lg font-bold text-text">Kontakt</h3>

        <ul class="space-y-3 mb-5">
          {contacts.map((c) => (
            <li class="flex items-center gap-3">
              <SvgIcon icon={c.icon} class="w-6 h-6 shrink-0 text-accent" label={c.label} />
              {c.href ? (
                <a
                  href={c.href}
                  class="text-sm text-text hover:text-accent transition-colors"
                  {...(('external' in c && c.external) ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {c.text}
                </a>
              ) : (
                <span class="text-sm text-text whitespace-pre-line">{c.text}</span>
              )}
            </li>
          ))}
        </ul>

        <!-- Map embed -->
        <div class="relative flex-1 overflow-hidden rounded-xl" style="padding-bottom:56.25%;min-height:180px;">
          <iframe
            title="Standort Circle of Life Jiu-Jitsu"
            loading="lazy"
            allowfullscreen
            referrerpolicy="no-referrer-when-downgrade"
            src="https://www.google.com/maps?q=Am+Herrschaftsweiher+17,+67071+Ludwigshafen+am+Rhein&output=embed"
            class="absolute inset-0 size-full border-0"
          ></iframe>
        </div>

        <p class="mt-3 flex items-center gap-2 text-xs text-text-faint">
          <SvgIcon icon={IconParking} class="w-5 h-5 shrink-0 text-accent" label="Parken" />
          Parken: ihr könnt gegenüber vom Eingang auf der Insel parken.
        </p>
      </div>

    </div>
  </div>
</section>
