---
import SvgIcon from '../ui/SvgIcon.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import {
  IconMapPin,
  IconPhone,
  IconEmail,
  IconWhatsApp,
} from '@/icons/index';

const distances = [
  '15\u00a0Min. aus Mannheim Zentrum',
  '12\u00a0Min. aus Frankenthal',
  '18\u00a0Min. aus Bad Dürkheim',
];
---

<section id="standort" class="cv-section bg-surface" style="padding:2.5em 0;">
  <div class="container">
    <SectionHeader
      title="Brazilian Jiu-Jitsu für Ludwigshafen &amp; die Rhein-Neckar-Region"
      subtitle="Unser Dojo liegt in Ludwigshafen-Ruchheim – wenige Minuten von Mannheim, Frankenthal, Bad Dürkheim und der BASF entfernt."
    />

    <div class="mb-6 grid grid-cols-1 gap-5 sm:grid-cols-2">
      <article
        class="rounded-2xl border border-border bg-white p-6 shadow-(--shadow-card)"
        data-aos="fade-up"
      >
        <h3 class="mb-3 text-base font-bold text-text">Grappling in der Nähe</h3>
        <p class="mb-4 text-sm leading-relaxed text-text-muted">
          Am Herrschaftsweiher 17 erreichst du uns über A650, B9 oder die L523.
          Parkplätze findest du direkt vor der Tür.
        </p>
        <ul class="space-y-2">
          {distances.map((d) => (
            <li class="flex items-center gap-2 text-sm text-text-muted">
              <SvgIcon icon={IconMapPin} class="w-4 h-4 shrink-0 text-accent" label="Entfernung" />
              {d}
            </li>
          ))}
        </ul>
      </article>

      <article
        class="rounded-2xl border border-border bg-white p-6 shadow-(--shadow-card)"
        data-aos="fade-up"
        data-aos-delay="100"
      >
        <h3 class="mb-3 text-base font-bold text-text">Lokale Community</h3>
        <p class="mb-3 text-sm leading-relaxed text-text-muted">
          Wir trainieren mit Mitgliedern aus Ludwigshafen, Mannheim, Speyer, Mutterstadt,
          Grünstadt und der gesamten Pfalz.
        </p>
        <p class="text-sm leading-relaxed text-text-muted">
          Du profitierst von kleinen Gruppen, persönlichem Coaching und klaren
          Progressions-Plänen für Gi &amp; No-Gi Grappling.
        </p>
      </article>
    </div>

    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 items-stretch">
      <div
        class="rounded-2xl border border-border bg-white p-6 shadow-(--shadow-card)"
        data-aos="fade-up"
      >
        <h3 class="mb-5 text-base font-bold text-text">Kontakt & Anfahrt</h3>
        <ul class="space-y-4">

          <li class="flex items-start gap-3">
            <SvgIcon icon={IconMapPin} class="w-6 h-6 shrink-0 text-accent mt-0.5" />
            <div>
              <p class="font-semibold text-sm text-primary">Circle of Life Jiu-Jitsu</p>
              <p class="text-text-muted text-sm">
                Am Herrschaftsweiher 17<br />
                67071 Ludwigshafen am Rhein
              </p>
            </div>
          </li>

          <li>
            <a href="tel:+4917661990534"
               class="flex items-center gap-3 text-text-muted hover:text-accent transition-colors text-sm">
              <SvgIcon icon={IconPhone} class="w-6 h-6 shrink-0 text-accent" />
              0176 61990534
            </a>
          </li>

          <li>
            <a href="mailto:mail.circleoflife@gmx.de"
               class="flex items-center gap-3 text-text-muted hover:text-accent transition-colors text-sm">
              <SvgIcon icon={IconEmail} class="w-6 h-6 shrink-0 text-accent" />
              mail.circleoflife@gmx.de
            </a>
          </li>

          <li>
            <a href="https://wa.me/4917661990534"
               target="_blank" rel="noopener"
               class="flex items-center gap-3 text-text-muted hover:text-accent transition-colors text-sm">
              <SvgIcon icon={IconWhatsApp} class="w-6 h-6 shrink-0 text-accent" />
              WhatsApp schreiben
            </a>
          </li>

        </ul>
      </div>

      <div
        class="flex flex-col rounded-2xl bg-dark-deeper p-6"
        data-aos="fade-up"
        data-aos-delay="150"
      >
        <p class="mb-1 text-xs font-semibold uppercase tracking-widest text-gold">Sofort starten</p>
        <h3 class="mb-3 text-lg font-bold" style="color:#fff;">Kostenloses Probetraining sichern</h3>
        <p class="mb-5 text-sm leading-relaxed text-white/75">
          Wir antworten innerhalb eines Werktags. Du brauchst nur Sportklamotten und Flip-Flops.
        </p>

        <div class="mt-auto flex flex-col gap-3">
          <a
            class="inline-flex items-center justify-center rounded-xl bg-accent py-2.5 text-sm font-bold text-primary transition-colors hover:bg-primary hover:text-white"
            href="#probetraining"
          >Formular öffnen</a>
          <a
            class="inline-flex items-center justify-center rounded-xl border-2 border-white/50 py-2.5 text-sm font-bold text-white transition-all hover:border-white hover:bg-white/10"
            target="_blank"
            href="https://www.google.com/maps?q=Am+Herrschaftsweiher+17,+67071+Ludwigshafen+am+Rhein"
            rel="noopener"
          >Route planen</a>
        </div>
      </div>
    </div>
  </div>
</section>
