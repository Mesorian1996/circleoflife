---
import { preise, preisHinweise } from '@/data/preise'
import PricingCard from '@/components/ui/PricingCard.astro'
import SectionHeader from '@/components/ui/SectionHeader.astro'
---

<section id="preise" class="py-16 md:py-24 bg-surface">
  <div class="container mx-auto max-w-6xl px-4">

    <SectionHeader
      eyebrow="Transparente Preise"
      title="Mitgliedschaft & Kurse"
      subtitle="Alle Preise für BJJ, Grappling und Zirkeltraining in Ludwigshafen – keine versteckten Kosten."
      align="center"
    />

    <!-- Mobile: 1-spaltig · Tablet: 2-spaltig · Desktop: 3-spaltig -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-12">
      {preise.map(p => (
        <PricingCard data={p} />
      ))}
    </div>

    <!-- Hinweise -->
    <div class="mt-8 flex flex-wrap justify-center gap-x-8 gap-y-2">
      {preisHinweise.map(h => (
        <p class="text-text-faint text-xs text-center">* {h}</p>
      ))}
    </div>

  </div>
</section>
