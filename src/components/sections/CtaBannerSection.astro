---
import ContactCta from '@/components/ui/ContactCta.astro';

interface Props {
  eyebrow?:    string;
  headline?:   string;
  subline?:    string;
  ctaLabel?:   string;
  ctaHref?:    string;
  cta2Label?:  string;
  cta2Href?:   string;
  showContact?: boolean;
  align?:      'left' | 'center';
}

const {
  eyebrow     = 'Bereit für die Matte?',
  headline    = 'Jetzt kostenloses Probetraining reservieren',
  subline     = 'Egal ob aus Ludwigshafen, Mannheim oder der Vorderpfalz – du bist willkommen. Einsteiger, Athleten und Kids gleichermaßen.',
  ctaLabel    = 'Probetraining sichern',
  ctaHref,
  cta2Label   = '0176 61990534 anrufen',
  cta2Href    = 'tel:+4917661990534',
  showContact = false,
  align       = 'left',
} = Astro.props;
---

<ContactCta
  eyebrow={eyebrow}
  headline={headline}
  subline={subline}
  ctaLabel={ctaLabel}
  ctaHref={ctaHref}
  cta2Label={cta2Label}
  cta2Href={cta2Href}
  showContact={showContact}
  align={align}
/>
