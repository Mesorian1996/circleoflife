---
import { Image } from 'astro:assets';
import SectionHeader from '../ui/SectionHeader.astro';
import trainerImg from '../../assets/images/Schwarzer_GI.jpeg';
---

<section id="trainer" class="cv-section bg-surface" style="padding:3em 0;">
  <div class="container">
    <SectionHeader
      title="Dein Trainer"
      subtitle="Erfahrung aus Wettkampf &amp; Lehre."
    />

    <article class="trainer-split" data-aos="fade-up">

      <div class="trainer-split__media">
        <Image
          src={trainerImg}
          alt="Headcoach Marvin Beck"
          title="Headcoach Marvin Beck"
          loading="lazy"
          widths={[360, 720]}
          sizes="(max-width: 767px) 95vw, 360px"
        />
      </div>

      <div class="trainer-split__content">
        <span style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--color-accent);">
          Headcoach
        </span>
        <h3 class="trainer-split__name">Marvin Beck</h3>
        <span class="trainer-split__belt">Black Belt</span>
        <p class="trainer-split__bio">
          Unser Headcoach Marvin Beck bringt jahrelange Erfahrung aus Brazilian Jiu-Jitsu,
          No-Gi Wettkämpfen und Martial Arts mit. Als Black Belt vermittelt er nicht nur Techniken,
          sondern ganze Systeme – von Guard-Game und Guard-Passing über Top-Control bis zu modernen Leg-Locks.
        </p>
        <blockquote class="trainer-split__quote">
          „Position before Submission – hier werden ganze Systeme beigebracht.
          Guard-Game, Guard-Passing, Top-Game und Leg-Locks."
        </blockquote>
      </div>

    </article>
  </div>
</section>
