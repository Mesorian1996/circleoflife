---
interface Props {
  badge?: string;
  title: string;
  lead: string;
  ctaLabel?: string;
  ctaHref?: string;
  anchors?: { href: string; label: string }[];
  note?: string;
  headingId?: string;
}

const {
  badge,
  title,
  lead,
  ctaLabel = 'Kostenloses Probetraining sichern',
  ctaHref  = '/#probetraining',
  anchors  = [],
  note,
  headingId,
} = Astro.props;
---

<section class="subpage-hero" aria-labelledby={headingId} data-aos="fade-up">
  <div class="container" style="padding-bottom:4rem;">
    {badge && <span class="subpage-badge">{badge}</span>}
    <h1 id={headingId}>{title}</h1>
    <p class="lead" style="max-width:65ch;" set:html={lead} />
    <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:1.5rem;">
      <a class="btn-brand btn-lg" href={ctaHref}>{ctaLabel}</a>
    </div>
    {note && (
      <p style="font-size:.875rem;color:rgba(255,255,255,.7);margin-top:.75rem;">{note}</p>
    )}
    {anchors.length > 0 && (
      <nav
        style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:1rem;"
        aria-label="Abschnitts-Shortcuts"
      >
        {anchors.map(a => (
          <a href={a.href} style="color:rgba(255,255,255,.75);font-size:.9rem;">{a.label}</a>
        ))}
      </nav>
    )}
  </div>
</section>
